# 이 파일을 복사해 .env로 저장 후 실제 값을 입력하세요.
# .env는 .gitignore에 포함되어 있어 커밋되지 않습니다.
# 배포(Netlify)에서는 Site settings → Environment variables 에 동일 키로 등록하세요.

# ── Supabase (클라이언트 노출 OK — RLS로 보호) ──
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── 공공데이터포털 (data.go.kr) — 서버 전용 ──
DATA_API_KEY=your-data-go-kr-service-key-here

# ── 네이버 OAuth (서버 전용) ──
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret
NAVER_STATE_SECRET=replace-with-long-random-string

# ── Supabase Admin (서버 전용, 탈퇴/네이버 콜백에서 사용) ──
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── 사이트 URL (콜백 redirect base) ──
SITE_URL=http://localhost:5173
